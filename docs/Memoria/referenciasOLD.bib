	address = {Rochester, NY},
	type = {{SSRN} {Scholarly} {Paper}},
	title = {Computers and {Student} {Learning}: {Bivariate} and {Multivariate} {Evidence} on the {Availability} and {Use} of {Computers} at {Home} and at {School}},
	shorttitle = {Computers and {Student} {Learning}},
	url = {https://papers.ssrn.com/abstract=619101},
	abstract = {We estimate the relationship between students' educational achievement and the availability and use of computers at home and at school in the international student-level PISA database. Bivariate analyses show a positive correlation between student achievement and the availability of computers both at home and at schools. However, once we control extensively for family background and school characteristics, the relationship gets negative for home computers and insignificant for school computers. Thus, the mere availability of computers at home seems to distract students from effective learning. But measures of computer use for education and communication at home show a positive conditional relationship with student achievement. The conditional relationship between student achievement and computer and internet use at school has an inverted U-shape, which may reflect either ability bias combined with negative effects of computerized instruction or a low optimal level of computerized instruction.},
	language = {en},
	number = {ID 619101},
	urldate = {2021-11-10},
	institution = {Social Science Research Network},
	author = {Woessmann, Ludger and Fuchs, Thomas},
	month = nov,
	year = {2004},
	keywords = {PISA, computers at home, computers at school, educational production, student achievement},
}

@article{gazmararian_impact_2021,
	title = {Impact of {COVID}-19 {Pandemic} on the {Mental} {Health} of {Students} {From} 2 {Semi}-{Rural} {High} {Schools} in {Georgia}*},
	volume = {91},
	issn = {1746-1561},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/josh.13007},
	doi = {10.1111/josh.13007},
	abstract = {BACKGROUND Concerns have been raised about the consequences of the COVID-19 pandemic on the mental health of adolescents during an important developmental and social period in their lives. This study examines the mental health impact of the pandemic on high school students shortly after closure of public schools in spring 2020, and whether this impact varies by sex, race/ethnicity, socioeconomic status (SES), and grade level. METHODS A cross-sectional, one-time online survey was completed by racial/ethnically and socioeconomically diverse students in 9th through 12th grade at 2 semi-rural Georgia public high schools (N = 761). RESULTS Overall, almost one-fourth of high school students were extremely or very worried about the pandemic, with higher rates of worry among students who are racial/ethnic minorities, lower SES, female and in older grades. Results indicated a concerning impact on the stress, anxiety, depression, and loneliness that students are feeling, particularly among girls and those in older grades. Students of color and low SES, who are already disproportionately impacted by COVID-19, are also more likely to experience mental health challenges. CONCLUSIONS Findings highlight important demographic differences of the impact of COVID-19 on the mental health of high school students and have implications for schools with addressing these needs.},
	language = {en},
	number = {5},
	urldate = {2021-11-10},
	journal = {Journal of School Health},
	author = {Gazmararian, Julie and Weingart, Rachel and Campbell, Katherine and Cronin, Thomas and Ashta, Jasleen},
	year = {2021},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/josh.13007},
	keywords = {COVID-19, adolescents, coronavirus, health disparities, mental health, stress},
	pages = {356--369},
}

