	editor = {Macedo, Pedro and Moutinho, Victor and Madaleno, Mara},
	year = {2023},
	doi = {10.1007/978-3-031-29583-6_4},
	keywords = {Eco-efficiency (EE), Economic and environmental applications, Literature review, Stochastic frontier analysis (SFA)},
	pages = {55--78},
}

@article{ruggiero_comparison_2007,
	title = {A comparison of {DEA} and the stochastic frontier model using panel data},
	volume = {14},
	issn = {1475-3995},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/j.1475-3995.2007.00585.x},
	doi = {10.1111/j.1475-3995.2007.00585.x},
	abstract = {Two competing approaches for the measurement of efficiency are the stochastic frontier model and data envelopment analysis (DEA). Previous research has established that the two models applied to cross-sectional data are both adversely affected by measurement error. While the cross-sectional stochastic frontier model does not effectively handle statistical noise, panel data models do. This is true because additional information from multiple time periods is incorporated into the estimation. A panel data DEA model that uses averaged data has been shown to effectively smooth out measurement error. In this paper, we compare the panel data models using simulated data.},
	language = {en},
	number = {3},
	urldate = {2024-04-04},
	journal = {International Transactions in Operational Research},
	author = {Ruggiero, John},
	year = {2007},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/j.1475-3995.2007.00585.x},
	keywords = {DEA, efficiency estimation, stochastic frontier},
	pages = {259--266},
}

