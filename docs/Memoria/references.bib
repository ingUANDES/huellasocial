@article{persico_theory_nodate,
	title = {A {Theory} of {Non}-{Democratic} {Redistribution} and {Public} {Good} {Provision}},
	abstract = {Two office-motivated politicians compete for power by making promises to citizens. Unlike in voting models, a citizens’ political activity is observable and subject to retaliation if the citizen happens to back the wrong politician. In equilibrium, a citizen supports the politician that is expected to win the political contest, not the one who promises her the most. Consequently, the incentives for politicians to redistribute resources and provide public goods are different from those in voting models. Citizens who are better able to coordinate with others receive more resources in equilibrium. A transition to democracy must come about through a citizen-led process, not a politician-led one.},
	language = {en},
	author = {Persico, Nicola},
}

